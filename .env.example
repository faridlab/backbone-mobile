# API Configuration
# Copy these to local.properties (gitignored) and set your machine's IP:
#   API_BASE_URL=http://192.168.1.25:3000
#   GRPC_WEB_URL=http://192.168.1.25:50051
#
# Defaults when not set:
#   Android emulator: http://10.0.2.2:3000 (maps to host machine)
#   iOS simulator:    http://localhost:3000
#   Release:          https://api.production.com
API_BASE_URL=http://localhost:3000
GRPC_WEB_URL=http://localhost:50051

# OAuth Configuration
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_ID=

# Crash Reporting (Sentry)
# Get DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=

# Feature Flags
ENABLE_ANALYTICS=false
